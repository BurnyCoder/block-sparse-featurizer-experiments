# Copy this file to .env and provide a Hugging Face token that has accepted the
# DINOv3 model terms. Never commit the populated .env file.
HF_TOKEN=

# The workbench is intentionally local-only by default.
BSF_HOST=127.0.0.1
BSF_PORT=7860
BSF_OUTPUT_DIR=outputs/runs
BSF_LOG_LEVEL=INFO
BSF_MAX_UPLOAD_MB=512
BSF_SESSION_TTL_SECONDS=3600
BSF_DEVICE=auto
